# Frontend -> backend API
# true: use backend API
# local dev default: http://localhost:8787
# deployed default: same-origin /api (Netlify Functions)
VITE_USE_BACKEND_API=true
VITE_BACKEND_BASE_URL=http://localhost:8787

# Backend / Netlify Functions runtime env
# export FASHN_API_KEY=xxxx
# export FASHN_BASE_URL=https://api.fashn.ai/v1
# export API_PORT=8787
# export SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# export SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
# export SUPABASE_STORAGE_BUCKET=app-assets
