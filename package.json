{
  "name": "my-vto-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-stack.mjs",
    "dev:web": "vite --port 5173 --strictPort",
    "api": "node server/mvpServer.js",
    "stack:start": "nohup npm run dev >/tmp/my-vto-dev.log 2>&1 </dev/null & sleep 2",
    "stack:stop": "pkill -f \"scripts/dev-stack.mjs\" || true; pkill -f mvpServer.js || true; pkill -f \"vite\" || true",
    "stack:status": "echo \"API:\" && curl -sS http://localhost:8787/api/health && echo \"\\n---DEV LOG---\" && tail -n 20 /tmp/my-vto-dev.log",
    "stack:restart": "npm run stack:stop && npm run stack:start",
    "stack": "npm run stack:restart && npm run stack:status",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "supabase": "^2.76.16",
    "vite": "^7.3.1"
  }
}
